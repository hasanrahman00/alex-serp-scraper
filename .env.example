# Server
PORT=3000

# DeepSeek AI (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 2Captcha (https://2captcha.com)  -- leave blank to disable auto-solve
TWOCAPTCHA_API_KEY=

# Browser
# Set to an existing CDP endpoint to attach (e.g. ws://127.0.0.1:9222/devtools/browser/...)
# Leave blank to launch a fresh Playwright Chromium.
CDP_ENDPOINT=
HEADLESS=false
SLOW_MO=0

# Scraper tuning
MAX_CONCURRENCY=2
NAV_TIMEOUT_MS=45000
PAGE_DELAY_MIN_MS=1500
PAGE_DELAY_MAX_MS=4000
USER_AGENT=
