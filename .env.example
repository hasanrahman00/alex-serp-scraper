# --- Server ---
PORT=3000

# --- Rotating residential proxy ---
# Mirrors a typical Webshare "Proxy List" page field-for-field.
# Webshare:                          IPRoyal:
#   PROXY_PROTOCOL=http                http
#   PROXY_HOST=p.webshare.io           geo.iproyal.com
#   PROXY_PORT=80                      12321
#   PROXY_USERNAME=user-rotate         user
#   PROXY_PASSWORD=pass                pass
PROXY_PROTOCOL=http
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# Alternative single-URL form (takes precedence if set):
#   PROXY_URL=http://user-rotate:pass@p.webshare.io:80

# Per-query sticky-session rotation. Requires a PAID proxy plan — Webshare
# FREE rejects -session syntax with HTTP 590 (scraper auto-disables on
# the first failure). Flip to true after upgrading.
PROXY_STICKY_SESSION=false

# --- Browser (optional — UI Settings → Browser usually covers this) ---
CDP_ENDPOINT=
HEADLESS=false
SLOW_MO=0

# --- Scraper tuning (optional) ---
NAV_TIMEOUT_MS=45000
PAGE_DELAY_MIN_MS=1500
PAGE_DELAY_MAX_MS=4000
USER_AGENT=
