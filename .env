# --- Server ---
PORT=3000

# --- Rotating residential proxy (Webshare) ---
# Mirrors the Webshare "Proxy List" screen field-for-field:
#   Proxy Protocol   →  HTTP
#   Domain Name      →  p.webshare.io
#   Proxy Port       →  80
#   Proxy Username   →  mtbxbpqv-rotate
#   Proxy Password   →  37adtq56ink2
PROXY_PROTOCOL=http
PROXY_HOST=p.webshare.io
PROXY_PORT=80
PROXY_USERNAME=mtbxbpqv-rotate
PROXY_PASSWORD=37adtq56ink2

# Per-query sticky-session rotation. Keep false on Webshare FREE tier
# (the free plan rejects -session syntax with HTTP 590; auto-disable in
# the scraper will catch it anyway). Flip to true on a paid plan.
PROXY_STICKY_SESSION=false

# --- Browser (optional overrides — UI Settings → Browser is usually enough) ---
CDP_ENDPOINT=
HEADLESS=false
SLOW_MO=0

# --- Scraper tuning (optional) ---
NAV_TIMEOUT_MS=45000
PAGE_DELAY_MIN_MS=1500
PAGE_DELAY_MAX_MS=4000
USER_AGENT=
